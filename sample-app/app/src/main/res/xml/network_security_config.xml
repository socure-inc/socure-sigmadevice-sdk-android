<?xml version="1.0" encoding="utf-8"?>
<network-security-config
    xmlns:android="http://schemas.android.com/apk/res/android">
    <base-config>
        <trust-anchors>
            <!-- Trust system CAs -->
            <certificates src="system"/>
            <!-- Trust user-installed CAs -->
            <certificates src="user"/>
        </trust-anchors>
    </base-config>
</network-security-config>